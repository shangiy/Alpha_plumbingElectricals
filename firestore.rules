
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to products, but only allow authenticated
    // admins or staff to write them.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'staff'];
    }
  }
}
