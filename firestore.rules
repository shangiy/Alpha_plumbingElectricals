
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access for the entire products collection and individual documents.
    // This allows listing products on category/search pages and viewing product details.
    match /products/{productId=**} {
      allow read: if true;
    }

    // Secure write access (create, update, delete) to the products collection.
    // Only authenticated users with the role of 'admin' or 'staff' can modify products.
    // Note: This rule is separate to avoid granting write access to the entire collection path.
    match /products/{productId} {
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'staff'];
    }

    // Secure user data. Users can only access their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
