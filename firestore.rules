
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Products can be read by anyone, but only written by admins/staff.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'staff');
    }

    // This rule allows the application to list all products, which is
    // necessary for category pages and the search page.
    match /products/{document=**} {
      allow read: if true;
    }
  }
}
